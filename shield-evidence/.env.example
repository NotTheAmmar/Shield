# SHIELD-EVIDENCE MICROSERVICE (TEMPLATE)
# Local dev environment mirroring docker-compose

# Storage (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PUBLIC_HOST=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_secure_minio_secret_key
BUCKET_NAME=evidence

# Database (Postgres)
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=shield_db_name

# Ledger / Auth Integration
MOCK_LEDGER=true
LEDGER_URL=http://localhost:4002

# Cryptography
MASTER_KEY=replace_this_with_a_32_byte_base64_key
JWT_SECRET=replace_this_with_a_secure_random_string